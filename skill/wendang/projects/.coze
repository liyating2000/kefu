[skill]
  skill_package = "prd-generator.skill"
  name = "prd-generator"
  description = "基于智能体原生能力的PRD生成器，支持从图片（流程图、界面设计图、原型图）和文字需求生成结构化的产品需求文档；支持批量图片解析和独立文件管理；具备主动提问、业务逻辑推断、专业审查机制；图片解析只描述可见内容不进行推断，PRD生成时进行业务逻辑推断含校验规则推断；每个页面及弹窗按优秀样例格式撰写；权限控制推断基于业务逻辑不明确时向用户提问；交互说明中的按钮描述使用双引号格式；遇到关键业务逻辑疑问时主动向用户提问不能猜测或假设"
  project_name = "需求文档技能"
  project_description = "智能PRD生成器"
